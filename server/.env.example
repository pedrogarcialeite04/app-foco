# PORT=3000
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/foco
# JWT_SECRET=<gerar string aleatória com 32+ caracteres>
# CORS_ORIGIN=https://seudominio.com
# HOST=0.0.0.0
# RATE_LIMIT_MAX_GLOBAL=100   (requisições por IP a cada 15 min)
# RATE_LIMIT_MAX_AUTH=10      (tentativas de login/register por IP a cada 15 min)
