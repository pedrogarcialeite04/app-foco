# ========== Desenvolvimento ==========
PORT=3001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/foco
JWT_SECRET=altere-este-segredo-em-producao-use-uma-string-longa-e-aleatoria
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5500

# ========== Produção (obrigatório para deploy) ==========
